{
  "name": "kong-manager",
  "private": true,
  "version": "0.0.0.0",
  "type": "module",
  "scripts": {
    "serve": "vite",
    "build": "vite build",
    "install:e2e": "pnpm install --filter playwright-tests",
    "test:e2e": "pnpm --filter playwright-tests run test",
    "playwright": "pnpm --filter playwright-tests exec playwright",
    "audit:prune-exclude": "node scripts/prune-min-release-age-exclude.mjs",
    "preview": "vite build && vite preview",
    "lint": "pnpm lint:eslint && pnpm lint:vue && pnpm lint:playwright && pnpm lint:style",
    "lint:eslint": "eslint src tests/playwright",
    "lint:eslint:fix": "eslint --fix src tests/playwright",
    "lint:playwright": "tsc --noEmit --project tests/playwright/tsconfig.json --baseUrl tests/playwright",
    "lint:style": "stylelint --allow-empty-input 'src/**/*.{css,scss,sass,less,styl,vue}'",
    "lint:vue": "vue-tsc --noEmit",
    "postinstall": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,js,vue}": "eslint --fix",
    "src/**/*.{css,scss,sass,less,styl,vue}": "stylelint --allow-empty-input --fix 'src/**/*.{css,scss,sass,less,styl,vue}'"
  },
  "dependencies": {
    "@kong-ui-public/app-layout": "^4.13.3",
    "@kong-ui-public/entities-certificates": "^3.16.5",
    "@kong-ui-public/entities-consumer-credentials": "^3.10.3",
    "@kong-ui-public/entities-consumers": "^4.6.3",
    "@kong-ui-public/entities-data-plane-nodes": "^0.8.4",
    "@kong-ui-public/entities-gateway-services": "^3.22.3",
    "@kong-ui-public/entities-key-sets": "^3.13.3",
    "@kong-ui-public/entities-keys": "^3.15.3",
    "@kong-ui-public/entities-plugins": "9.248.1",
    "@kong-ui-public/entities-routes": "3.24.3",
    "@kong-ui-public/entities-shared": "^3.57.3",
    "@kong-ui-public/entities-snis": "^3.14.3",
    "@kong-ui-public/entities-upstreams-targets": "^3.16.3",
    "@kong-ui-public/entities-vaults": "^4.16.3",
    "@kong-ui-public/forms": "4.33.3",
    "@kong-ui-public/i18n": "^2.5.0",
    "@kong-ui-public/misc-widgets": "^2.5.2",
    "@kong-ui-public/monaco-editor": "^0.24.2",
    "@kong/icons": "^1.61.2",
    "@kong/kongponents": "9.61.8",
    "@material-design-icons/font": "^0.14.13",
    "axios": "^1.18.1",
    "dayjs": "^1.11.13",
    "monaco-editor": "0.52.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@kong/design-tokens": "^3.0.3",
    "@kong/eslint-config-kong-ui": "^1.7.1",
    "@kong/stylelint-plugin-design-tokens": "^2.0.0",
    "@playwright/test": "^1.61.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.4.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.20",
    "bmp-js": "^0.1.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.9.1",
    "eslint-plugin-playwright": "^1.6.2",
    "eslint-plugin-vuejs-accessibility": "^2.3.0",
    "husky": "^9.1.5",
    "lint-staged": "^15.2.10",
    "lodash-es": "^4.18.1",
    "rollup-plugin-visualizer": "^5.12.0",
    "sass": "^1.80.3",
    "stylelint": "^16.9.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended-scss": "^14.1.0",
    "stylelint-config-recommended-vue": "^1.5.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vite-plugin-html": "^3.2.2",
    "vue-tsc": "^3.3.7"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not IE <= 11"
  ],
  "packageManager": "pnpm@11.10.0"
}
